{"id": "nat_043", "mode": "text", "text": "Due to the heavy snowfall overnight, all schools in the district will be closed today.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
{"id": "nat_044", "mode": "text", "text": "Now is the time for all good men to come to the aid of their country.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
{"id": "nat_045", "mode": "text", "text": "Thank you for calling, your business is important to us and we will be with you shortly.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
{"id": "nat_046", "mode": "text", "text": "If this is a medical emergency, please hang up and dial nine one one immediately.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
{"id": "nat_047", "mode": "text", "text": "She walked along the seashore at sunset, listening to the gentle sound of waves on the sand.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
