{"id": "nat_001", "mode": "text", "text": "Time to go.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_002", "mode": "text", "text": "No thanks.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_003", "mode": "text", "text": "Open the door.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_004", "mode": "text", "text": "Yes please.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_005", "mode": "text", "text": "All systems go.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_006", "mode": "text", "text": "Hold the line please.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_007", "mode": "text", "text": "Close the window.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_008", "mode": "text", "text": "It is raining.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_009", "mode": "text", "text": "Right now.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_010", "mode": "text", "text": "Press any key.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_011", "mode": "text", "text": "Lights off please.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_012", "mode": "text", "text": "Wait one moment.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_013", "mode": "text", "text": "Good morning.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_014", "mode": "text", "text": "Speak after the tone.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_015", "mode": "text", "text": "Welcome back.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_016", "mode": "text", "text": "Turn on the lights.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_017", "mode": "text", "text": "Not yet.", "tags": ["nat", "stratum=natural", "length_bucket=short", "seed=42"]}
{"id": "nat_018", "mode": "text", "text": "This message is being recorded for quality assurance.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_019", "mode": "text", "text": "All passengers must remain seated until we land.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_020", "mode": "text", "text": "Please stay on the line for the next available agent.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_021", "mode": "text", "text": "The library will be closed on Monday for the holiday.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_022", "mode": "text", "text": "The fire alarm test will run for thirty seconds.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_023", "mode": "text", "text": "Please leave your name and number after the beep.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_024", "mode": "text", "text": "The road ahead is closed due to ongoing construction.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_025", "mode": "text", "text": "Press one for sales, two for support, three for billing.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_026", "mode": "text", "text": "Please return your tray tables to the upright position.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_027", "mode": "text", "text": "Your package will arrive between three and five today.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_028", "mode": "text", "text": "The weather today is partly cloudy with light winds.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_029", "mode": "text", "text": "The next train to the airport leaves in ten minutes.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_030", "mode": "text", "text": "Office hours are from nine in the morning until five.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_031", "mode": "text", "text": "Your appointment is confirmed for Tuesday at two o'clock.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_032", "mode": "text", "text": "All circuits are busy, please try your call later.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_033", "mode": "text", "text": "Mind the gap between the train and the platform.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_034", "mode": "text", "text": "The current temperature is sixty eight degrees.", "tags": ["nat", "stratum=natural", "length_bucket=medium", "seed=42"]}
{"id": "nat_035", "mode": "text", "text": "Our records indicate that your subscription expired last month, please renew to continue uninterrupted service.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
{"id": "nat_036", "mode": "text", "text": "We are experiencing a higher than usual call volume and apologize for the longer wait time.", "tags": ["nat", "stratum=natural", "length_bucket=long", "seed=42"]}
