{
  "name": "spfy-wasm-demo",
  "version": "0.1.0",
  "private": true,
  "description": "In-browser WebAssembly demo of the Speechify 3.0.5 synth engine.",
  "type": "module",
  "scripts": {
    "build:wasm":  "bash build.sh",
    "build":       "webpack --mode production",
    "build:dist":  "npm run build && npm run pack",
    "pack":        "node tools/compress_dist.mjs",
    "dev":         "webpack serve --mode development --open"
  },
  "devDependencies": {
    "compression":           "^1.7.5",
    "copy-webpack-plugin":   "^12.0.2",
    "html-webpack-plugin":   "^5.6.3",
    "webpack":               "^5.95.0",
    "webpack-cli":           "^5.1.4",
    "webpack-dev-server":    "^5.1.0"
  }
}
